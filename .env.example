# Local + Railway Supabase config. Copy to `.env` for local dev, or set the
# non-VITE_ vars as Railway project variables and the VITE_ vars as BOTH
# build-time and runtime variables (Vite inlines VITE_ vars at build time).
#
# Replace every REPLACE_WITH_* value with your NEW Supabase project's values.
# Get them from the project's API settings.
#   - SUPABASE_URL                 -> Project URL
#   - SUPABASE_PUBLISHABLE_KEY    -> anon / publishable key (sb_publishable_...)
#   - VITE_SUPABASE_URL           -> same as SUPABASE_URL
#   - VITE_SUPABASE_PUBLISHABLE_KEY -> same as SUPABASE_PUBLISHABLE_KEY
#   - SUPABASE_SERVICE_ROLE_KEY   -> service_role key (SERVER ONLY — never VITE_-prefixed)

SUPABASE_URL="REPLACE_WITH_NEW_PROJECT_URL"
SUPABASE_PUBLISHABLE_KEY="REPLACE_WITH_NEW_PUBLISHABLE_KEY"

VITE_SUPABASE_URL="REPLACE_WITH_NEW_PROJECT_URL"
VITE_SUPABASE_PUBLISHABLE_KEY="REPLACE_WITH_NEW_PUBLISHABLE_KEY"

# SERVER ONLY — do not expose to the browser. Set in Railway (runtime) and locally in `.env`.
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_NEW_SERVICE_ROLE_KEY"
